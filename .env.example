# Copy to `.env` next to compose.yml. `.env` is gitignored.
# Generate secrets with:  openssl rand -base64 32 | tr -d '=+/' | cut -c1-40

# --- Flask app secrets ---
METAWAHL_SECRET=change-me-flask-session-key
METAWAHL_ADMIN_KEY=change-me-admin-key

# --- Database (consumed by api service) ---
POSTGRES_USER=metawahl
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_DB=metawahl

# Exposed to the api container; host/port match the `db` service in compose.yml.
METAWAHL_DB_URL=postgresql://metawahl:change-me-db-password@db:5432/metawahl

# --- Cache ---
CACHE_REDIS_URL=redis://redis:6379/0

# --- Config file path (inside the api container) ---
METAWAHL_CONFIG=/app/api/app/prod.conf.py

# --- Log file path (inside the api container; bind-mounted to ./logs) ---
METAWAHL_API_LOGFILE=/var/log/metawahl/flask.log
